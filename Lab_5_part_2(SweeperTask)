package org.example

import org.gradle.api.DefaultTask
import org.gradle.api.tasks.TaskAction
import java.time.Instant
import java.time.temporal.ChronoUnit

class SweeperTask extends DefaultTask {

    @TaskAction
    void sweep() {
        def extension = project.extensions.findByType(SweeperExtension)
        int days = extension ? extension.daysToKeep : 3
        def cutoffDate = Instant.now().minus(days, ChronoUnit.DAYS)

        println "=== Запуск Smart Sweeper (daysToKeep = ${days}) ==="

        def srcDir = project.file("src")
        if (srcDir.exists()) {
            def dirs = []
            srcDir.eachDirRecurse { dirs << it }
            dirs.reverseEach { dir ->
                if (dir.list().length == 0) {
                    println "Сміттяр: Видалено порожню папку -> ${dir.absolutePath}"
                    dir.delete()
                }
            }
        }

        def libsDir = project.file("build/libs")
        if (libsDir.exists()) {
            libsDir.eachFileMatch(~/.*\.jar$/) { file ->
                def lastModified = Instant.ofEpochMilli(file.lastModified())
                if (lastModified.isBefore(cutoffDate)) {
                    println "Сміттяр: Видалено старий артефакт -> ${file.name}"
                    file.delete()
                }
            }
        } else {
            println "Сміттяр: Папку build/libs не знайдено, артефактів для видалення немає."
        }

        println "==================================================="
    }
}
